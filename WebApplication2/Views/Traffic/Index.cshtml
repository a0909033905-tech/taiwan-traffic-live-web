@model IEnumerable<WebApplication2.Models.TrafficEvent>

@{
    Layout = null; // 若專案有 _Layout 可移除此行，讓頁面使用全域 layout
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <title>全台即時交通路況查詢系統</title>
    <!-- Bootstrap CSS (CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            padding: 20px;
            background: #f8f9fa;
        }
        .card-event {
            margin-bottom: 16px;
        }
        .badge-region {
            font-size: 0.9rem;
        }
        .filter-row {
            margin-bottom: 20px;
        }
        .no-data {
            padding: 40px 0;
            text-align: center;
            color: #666;
        }
        .small-muted {
            color: #6c757d;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2 class="mb-3">全台即時交通路況查詢系統</h2>
        @if (!string.IsNullOrEmpty((string)ViewBag.ErrorMessage))
        {
            <div class="alert alert-warning" role="alert">@ViewBag.ErrorMessage</div>
        }

        <form method="get" class="row gx-2 gy-2 align-items-end filter-row">
            <div class="col-auto">
                <label class="form-label">地區</label>
                <select name="region" class="form-select">
                    @foreach (var r in (List<string>)ViewBag.Regions)
                    {
                        <option value="@r" selected="@(r == (string)ViewBag.SelectedRegion ? "selected" : null)">@r</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">事件類型</label>
                <select name="eventType" class="form-select">
                    @foreach (var t in (List<string>)ViewBag.EventTypes)
                    {
                        <option value="@t" selected="@(t == (string)ViewBag.SelectedEventType ? "selected" : null)">@t</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">篩選</button>
                <a class="btn btn-outline-secondary" href="/Traffic">重設</a>
            </div>
            <div class="col-auto ms-auto text-end">
                <div class="small-muted">顯示筆數：<strong>@ViewBag.TotalCount</strong></div>
            </div>
        </form>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
            @if (!Model.Any())
            {
                <div class="col-12">
                    <div class="no-data bg-white rounded shadow-sm">
                        <p class="mb-0">查無符合條件的事件。</p>
                    </div>
                </div>
            }
            else
            {
                foreach (var ev in Model)
                {
                    <div class="col">
                        <div class="card card-event h-100 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title mb-0">@ev.EventType</h5>
                                    <span class="badge bg-info text-dark badge-region">@ev.Region</span>
                                </div>

                                <p class="mb-1"><strong>道路：</strong>@ev.RoadName</p>
                                <p class="mb-1"><strong>方向：</strong>@ev.Direction</p>
                                <p class="mb-1"><strong>地點：</strong>@ev.Location</p>
                                <p class="mb-1"><strong>發生時間：</strong>@ev.OccurredAt.ToString("yyyy/MM/dd HH:mm")</p>
                                <hr />
                                <p class="mb-1"><strong>說明：</strong>@ev.Description</p>
                                <p class="mb-0"><strong>生活建議：</strong> @ev.Advice</p>
                            </div>
                            <div class="card-footer small text-muted">
                                事件ID：@ev.Id
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Bootstrap JS (CDN) for optional components -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

